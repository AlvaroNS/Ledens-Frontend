{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/*.{png,jpg,jpeg,gif,svg,ico,webp,js,css,woff,woff2,ttf,otf,eot,map,txt,xml,json}"]
  },
  "routes": [
    {
      "route": "/assets/*",
      "headers": { "cache-control": "public, max-age=31536000, immutable" }
    }
  ],
  "mimeTypes": {
    ".json": "application/json"
  }
}
