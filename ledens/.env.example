# Host port that nginx (frontend container) is exposed on
HOST_PORT=8080

# CORS origin allowed by the backend. When the frontend is served by the
# bundled nginx and proxies /api -> backend internally, leaving this as the
# nginx host URL is enough.
CORS_ORIGIN=http://localhost:8080

# Clerk publishable key (https://dashboard.clerk.com). Consumed at frontend
# build time — Vite inlines it into the bundle. Missing => the auth buttons
# render a console error on boot.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
